# === Supabase ===
# URL do projeto (Settings → API)
SUPABASE_URL=https://your-project-ref.supabase.co
# Chave pública (anon) — usada quando o backend age em nome do usuário (RLS aplicada)
SUPABASE_ANON_KEY=your-anon-key
# Chave de serviço — bypass da RLS, uso restrito a jobs/admin. NUNCA expor no frontend.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# === Anthropic ===
# Chave da API. Console: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-key
# Modelo padrão do backend
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# === Autenticação ===
# Segredo para assinar JWT próprios (se rodarmos além do Supabase Auth)
JWT_SECRET=change-me-generate-a-strong-random-string

# === Servidor ===
PORT=3333
NODE_ENV=development
# CORS origem do frontend
FRONTEND_ORIGIN=http://localhost:3000
